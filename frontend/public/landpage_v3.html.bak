<script>
// Scroll reveal
const obs = new IntersectionObserver(entries=>{
  entries.forEach(e=>{ if(e.isIntersecting) e.target.classList.add('vis') })
},{threshold:.06,rootMargin:'0px 0px -40px 0px'})
document.querySelectorAll('.rv,.rv2').forEach(el=>obs.observe(el))

// FAQ
function toggleFaq(el) {
  const item = el.parentElement
  const isOpen = item.classList.contains('open')
  document.querySelectorAll('.faq-item').forEach(i=>i.classList.remove('open'))
  if(!isOpen) item.classList.add('open')
}

// Freq card colors
const FREQ_COLORS = {396:'rgba(74,222,128,.5)',417:'rgba(100,180,255,.5)',528:'rgba(196,181,253,.7)',639:'rgba(255,180,100,.5)',741:'rgba(232,197,71,.6)',852:'rgba(255,120,120,.5)',963:'rgba(180,100,255,.6)'}
const FREQ_NAMES = {396:'Liberação',417:'Mudança',528:'Transformação',639:'Conexão',741:'Expressão',852:'Ordem',963:'Consciência'}

// PHONEMES
const PHONEMES={a:'expansão',b:'sustentação',c:'criatividade',d:'determinação',e:'expressão',f:'fluidez',g:'crescimento',h:'elevação',i:'intuição',j:'sabedoria',k:'estabilidade',l:'leveza',m:'propósito',n:'renovação',o:'conexão',p:'proteção',q:'clareza',r:'movimento',s:'pureza',t:'transformação',u:'unidade',v:'vitalidade',w:'força',x:'transmutação',y:'harmonia',z:'equilíbrio'}
const VEDIC={1:{planet:'Sol',quality:'liderança'},2:{planet:'Lua',quality:'intuição'},3:{planet:'Júpiter',quality:'sabedoria'},4:{planet:'Rahu',quality:'transformação'},5:{planet:'Mercúrio',quality:'comunicação'},6:{planet:'Vênus',quality:'amor'},7:{planet:'Ketu',quality:'espiritualidade'},8:{planet:'Saturno',quality:'disciplina'},9:{planet:'Marte',quality:'energia'}}
const YAZATA={1:'Hormozd',2:'Bahman',3:'Ardibehesht',4:'Shahrivar',5:'Espandarmaz',6:'Khordad',7:'Amordad',8:'Daepadar',9:'Azar',10:'Aban',11:'Khorshed',12:'Mah',13:'Tir',14:'Gosh',15:'Daepamihr',16:'Mihr',17:'Srosh',18:'Rashn',19:'Farvardin',20:'Bahram',21:'Ram',22:'Bad',23:'Daepadin',24:'Din',25:'Ard',26:'Ashtad',27:'Asman',28:'Zamyad',29:'Mahraspand',30:'Anagran'}
const SEQUENCES={paz:[396,528,417,963],prosperidade:[528,639,741,852],protecao:[396,417,528,741],foco:[417,528,741,963],amor:[528,639,852,963],transformacao:[396,417,639,741]}
const DURATIONS={1:38,2:25,3:21,4:32,5:18,6:28,7:22,8:35,9:30}

function vedicNum(dateStr){
  if(!dateStr)return{number:5,planet:'Mercúrio',quality:'comunicação'}
  const d=dateStr.replace(/[^0-9]/g,'').split('').map(Number)
  let s=d.reduce((a,b)=>a+b,0)
  while(s>9)s=String(s).split('').map(Number).reduce((a,b)=>a+b,0)
  return{number:s,...(VEDIC[s]||VEDIC[5])}
}

function getCurrentFreqIdx(sequence,durMin){
  const now=new Date()
  const minsToday=now.getHours()*60+now.getMinutes()
  return Math.floor(minsToday/durMin)%sequence.length
}

function calcDemo(){
  const name=document.getElementById('d-name').value||'Danilo'
  const date=document.getElementById('d-date').value
  const intent=document.getElementById('d-intent').value

  // Mantra
  const letters=[...new Set(name.toLowerCase().replace(/[^a-z]/g,'').split(''))].slice(0,4)
  const qualities=letters.map(l=>PHONEMES[l]||'luz').join(' · ')
  const syllables=letters.map(l=>l.toUpperCase()+'a').join('·')
  const mantra=`Om ${syllables} Namah`

  // Vedic
  const vedic=vedicNum(date)
  const durMin=DURATIONS[vedic.number]||21

  // Sequence
  const seq=SEQUENCES[intent]||SEQUENCES.paz
  const currentIdx=getCurrentFreqIdx(seq,durMin)
  const currentFreq=seq[currentIdx]

  // Yazata
  const day=date?new Date(date).getDate():16
  const yaz=YAZATA[day]||'Mihr'

  // Update DOM
  document.getElementById('dr-mantra').textContent=mantra
  document.getElementById('dr-meaning').textContent=`Honro a vibração de ${qualities} em mim`
  document.getElementById('dr-freq-main').textContent=currentFreq+' Hz'
  document.getElementById('dr-freq-name').textContent=FREQ_NAMES[currentFreq]||''

  // Sequence list
  let seqHTML=''
  seq.forEach((hz,i)=>{
    const isNow=i===currentIdx
    const startMin=(i*durMin)%1440
    const h=Math.floor(startMin/60).toString().padStart(2,'0')
    const m=(startMin%60).toString().padStart(2,'0')
    seqHTML+=`<div class="dr-seq-item">
      <div class="dr-seq-hz">${hz}</div>
      <div class="dr-seq-info">
        <div class="dr-seq-name">${FREQ_NAMES[hz]}${isNow?'<span class="dr-seq-now">▶ agora</span>':''}</div>
        <div class="dr-seq-time">${durMin} min · ciclo ${i+1} de ${seq.length}</div>
      </div>
    </div>`
  })
  document.getElementById('dr-sequence').innerHTML=seqHTML

  // Explain
  document.getElementById('dex-fonemas').textContent=syllables
  document.getElementById('dex-fonemas-desc').textContent=`Letras de "${name}" → ${qualities}`
  document.getElementById('dex-vedic').textContent=`${vedic.number} — ${vedic.planet}`
  document.getElementById('dex-vedic-desc').textContent=`${vedic.quality} · ritmo de ${durMin} min por frequência`
  document.getElementById('dex-yazata').textContent=yaz
  document.getElementById('dex-yazata-desc').textContent=`Yazata do dia ${day} do mês de nascimento`

  document.getElementById('demo-result').classList.add('show')
  document.getElementById('dr-explain').classList.add('show')
  document.getElementById('demo-result').scrollIntoView({behavior:'smooth',block:'nearest'})
}
</script>
</body>
</html>
