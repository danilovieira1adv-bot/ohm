<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>ŌHM — Vibrações Sagradas Personalizadas | Streaming 24/7</title>
<meta name="description" content="O único sistema de streaming vibracional personalizado do Brasil. Baseado nas 7 frequências Solfeggio, sânscrito védico e tradições milenares. Para você, seu espaço ou negócio."/>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
:root{
  --void:#04010c; --ink:#080514; --surface:#0f0b1c; --surface2:#161228;
  --indigo:#534AB7; --indigo2:#7B74D4; --iglow:rgba(83,74,183,.14);
  --lav:#c4b5fd; --lavd:rgba(196,181,253,.5); --lavg:rgba(196,181,253,.1);
  --gold:#E8C547; --goldd:rgba(232,197,71,.6); --golddim:rgba(232,197,71,.15);
  --text:#e2d9f3; --textd:rgba(226,217,243,.6); --textg:rgba(226,217,243,.2);
  --border:rgba(196,181,253,.08); --border2:rgba(196,181,253,.16);
  --green:#4ade80; --greend:rgba(74,222,128,.15);
}
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{background:var(--void);color:var(--text);font-family:'DM Sans',sans-serif;font-weight:300;overflow-x:hidden;line-height:1.6}
body::before{content:'';position:fixed;inset:0;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='.025'/%3E%3C/svg%3E");pointer-events:none;z-index:999;opacity:.5}
::-webkit-scrollbar{width:3px}::-webkit-scrollbar-thumb{background:var(--indigo);border-radius:2px}

/* NAV */
nav{position:fixed;top:0;left:0;right:0;z-index:100;padding:1.1rem 4rem;display:flex;align-items:center;justify-content:space-between;background:rgba(4,1,12,.8);backdrop-filter:blur(24px);border-bottom:.5px solid var(--border)}
.nlogo{font-family:'Cormorant Garamond',serif;font-size:1.4rem;font-weight:300;letter-spacing:.25em;color:var(--lav)}
.nlinks{display:flex;align-items:center;gap:2.25rem;list-style:none}
.nlinks a{color:var(--textd);text-decoration:none;font-size:.72rem;letter-spacing:.1em;text-transform:uppercase;transition:color .3s}
.nlinks a:hover{color:var(--lav)}
.ncta{border:.5px solid rgba(196,181,253,.3) !important;color:var(--lav) !important;padding:.42rem 1.25rem;border-radius:100px;transition:all .3s !important}
.ncta:hover{background:var(--iglow) !important;border-color:var(--lavd) !important}

/* HERO */
.hero{min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;position:relative;padding:8rem 2rem 5rem;text-align:center;overflow:hidden}
.hero-mesh{position:absolute;inset:0;background:radial-gradient(ellipse 80% 60% at 50% 40%,rgba(83,74,183,.1) 0%,transparent 70%),radial-gradient(ellipse 40% 40% at 80% 70%,rgba(232,197,71,.05) 0%,transparent 60%),radial-gradient(ellipse 35% 35% at 20% 30%,rgba(196,181,253,.05) 0%,transparent 60%);pointer-events:none}
.om-hero{position:absolute;font-family:'Cormorant Garamond',serif;font-size:clamp(10rem,22vw,18rem);color:var(--lav);opacity:.055;top:50%;left:50%;transform:translate(-50%,-52%);pointer-events:none;animation:breathe 12s ease-in-out infinite;line-height:1;letter-spacing:-.02em}
@keyframes breathe{0%,100%{opacity:.04;transform:translate(-50%,-52%) scale(1)}50%{opacity:.09;transform:translate(-50%,-52%) scale(1.03)}}
.hero-live{display:inline-flex;align-items:center;gap:.5rem;background:rgba(74,222,128,.08);border:.5px solid rgba(74,222,128,.2);border-radius:100px;padding:.35rem 1rem;font-size:.65rem;letter-spacing:.15em;text-transform:uppercase;color:rgba(74,222,128,.8);margin-bottom:1.75rem;position:relative;z-index:2;animation:fadeUp 1s ease .1s both}
.live-dot{width:5px;height:5px;border-radius:50%;background:var(--green);animation:pulse 1.5s infinite}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.4;transform:scale(.8)}}
.hero-eyebrow{font-size:.62rem;letter-spacing:.28em;text-transform:uppercase;color:var(--goldd);margin-bottom:1.25rem;position:relative;z-index:2;animation:fadeUp 1s ease .2s both}
.hero-title{font-family:'Cormorant Garamond',serif;font-size:clamp(3.5rem,11vw,8.5rem);font-weight:300;letter-spacing:.12em;color:var(--lav);line-height:.95;position:relative;z-index:2;animation:fadeUp 1s ease .35s both}
.hero-title span{display:block;font-size:clamp(1.2rem,3vw,2rem);font-style:italic;color:var(--textd);letter-spacing:.04em;margin-top:.5rem;font-weight:300}
.hero-desc{max-width:580px;font-size:.95rem;color:var(--textd);line-height:1.9;margin-top:1.75rem;position:relative;z-index:2;animation:fadeUp 1s ease .55s both}
.hero-acts{display:flex;gap:1rem;margin-top:2.5rem;position:relative;z-index:2;animation:fadeUp 1s ease .7s both;flex-wrap:wrap;justify-content:center}
.btn-p{background:var(--indigo);color:white;border:none;padding:.92rem 2.5rem;border-radius:100px;font-family:'DM Sans',sans-serif;font-size:.88rem;font-weight:400;letter-spacing:.03em;cursor:pointer;text-decoration:none;display:inline-block;transition:all .3s}
.btn-p:hover{transform:translateY(-2px);box-shadow:0 10px 35px rgba(83,74,183,.45)}
.btn-g{background:transparent;color:var(--lavd);border:.5px solid var(--border2);padding:.88rem 2.5rem;border-radius:100px;font-family:'DM Sans',sans-serif;font-size:.88rem;cursor:pointer;text-decoration:none;display:inline-block;transition:all .3s}
.btn-g:hover{border-color:var(--lavd);color:var(--lav)}
.btn-gold{background:var(--gold);color:#1a1000;border:none;padding:.92rem 2.5rem;border-radius:100px;font-family:'DM Sans',sans-serif;font-size:.88rem;font-weight:500;cursor:pointer;text-decoration:none;display:inline-block;transition:all .3s}
.btn-gold:hover{transform:translateY(-2px);box-shadow:0 10px 35px rgba(232,197,71,.35)}

/* FREQ VISUALIZER */
.freq-vis{display:flex;align-items:center;justify-content:center;gap:5px;margin:3rem 0 0;position:relative;z-index:2;animation:fadeUp 1s ease .85s both;height:48px}
.fbar{width:3px;border-radius:2px;background:var(--indigo);opacity:.4;animation:fwave 2.5s ease-in-out infinite}
@keyframes fwave{0%,100%{transform:scaleY(1)}50%{transform:scaleY(2.8)}}
@keyframes fadeUp{from{opacity:0;transform:translateY(22px)}to{opacity:1;transform:translateY(0)}}

/* TRUST */
.trust{background:var(--ink);border-top:.5px solid var(--border);border-bottom:.5px solid var(--border);padding:1.1rem 4rem;display:flex;align-items:center;justify-content:center;gap:2.75rem;flex-wrap:wrap}
.trust-item{display:flex;align-items:center;gap:.5rem;font-size:.68rem;color:var(--textd);letter-spacing:.06em}
.trust-dot{width:3px;height:3px;border-radius:50%;background:var(--indigo2);flex-shrink:0}

/* DIVIDER */
.divider{height:.5px;background:var(--border);max-width:1100px;margin:0 auto}

/* SECTIONS */
.sec{padding:6rem 2rem;max-width:1100px;margin:0 auto}
.sec-sm{padding:4rem 2rem;max-width:1100px;margin:0 auto}
.sec-label{font-size:.6rem;letter-spacing:.28em;text-transform:uppercase;color:var(--goldd);margin-bottom:.65rem;display:block}
.sec-title{font-family:'Cormorant Garamond',serif;font-size:clamp(1.8rem,4.5vw,3.2rem);font-weight:300;color:var(--lav);line-height:1.15;margin-bottom:1.1rem}
.sec-title em{font-style:italic;color:var(--textd)}
.sec-body{font-size:.9rem;color:var(--textd);line-height:1.9;max-width:580px}

/* THE 7 FREQUENCIES — HERO SECTION */
.freq7-intro{text-align:center;margin-bottom:3.5rem}
.freq7-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:.75rem;margin-bottom:2rem}
.freq7-card{background:var(--surface);border:.5px solid var(--border);border-radius:16px;padding:1.5rem 1rem;text-align:center;position:relative;overflow:hidden;transition:all .35s;cursor:default}
.freq7-card::before{content:'';position:absolute;bottom:0;left:0;right:0;height:2px;transition:opacity .3s;opacity:0}
.freq7-card:hover{background:var(--surface2);border-color:var(--border2);transform:translateY(-4px)}
.freq7-card:hover::before{opacity:1}
.freq7-hz{font-family:'Cormorant Garamond',serif;font-size:1.8rem;font-weight:300;color:var(--gold);opacity:.8;line-height:1;margin-bottom:.3rem}
.freq7-name{font-size:.7rem;font-weight:500;color:var(--lav);margin-bottom:.5rem;letter-spacing:.03em}
.freq7-intent{font-size:.62rem;color:var(--textd);line-height:1.55}
.freq7-origin{font-size:.58rem;color:var(--textg);margin-top:.5rem;font-style:italic}
.freq7-bar{height:2px;border-radius:1px;margin-bottom:.85rem;opacity:.6}

/* SOLFEGGIO SPECTRUM */
.solfeggio-spectrum{background:var(--surface);border:.5px solid var(--border);border-radius:24px;padding:2.5rem;margin-top:2rem;position:relative;overflow:hidden}
.solfeggio-spectrum::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,#396,#417hz,#528hz,#639hz,#741hz,#852hz,#963hz);background:linear-gradient(90deg,rgba(74,222,128,.6),rgba(100,180,255,.6),rgba(196,181,253,.8),rgba(255,180,100,.6),rgba(232,197,71,.8),rgba(255,120,120,.6),rgba(180,100,255,.8))}
.spectrum-title{font-size:.65rem;letter-spacing:.2em;text-transform:uppercase;color:var(--textg);margin-bottom:1.5rem;text-align:center}
.spectrum-bars{display:flex;align-items:flex-end;gap:8px;height:80px;justify-content:center}
.spec-bar{border-radius:3px 3px 0 0;opacity:.7;transition:all .3s;cursor:pointer;position:relative}
.spec-bar:hover{opacity:1;transform:scaleY(1.1);transform-origin:bottom}
.spec-label{position:absolute;bottom:-20px;left:50%;transform:translateX(-50%);font-size:.55rem;color:var(--textg);white-space:nowrap}

/* HOW PERSONALIZATION WORKS */
.persona-flow{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:var(--border);border-radius:20px;overflow:hidden;margin-top:3rem}
.pf-block{background:var(--surface);padding:2.25rem 1.75rem;position:relative;transition:background .3s}
.pf-block:hover{background:var(--surface2)}
.pf-num{font-family:'Cormorant Garamond',serif;font-size:3rem;font-weight:300;color:var(--indigo);opacity:.35;line-height:1;margin-bottom:1.25rem}
.pf-title{font-size:.78rem;font-weight:500;color:var(--lav);margin-bottom:.5rem;letter-spacing:.03em}
.pf-desc{font-size:.78rem;color:var(--textd);line-height:1.7}
.pf-example{margin-top:.85rem;background:var(--iglow);border:.5px solid rgba(83,74,183,.18);border-radius:9px;padding:.65rem .9rem;font-size:.7rem;color:var(--lav);font-style:italic;line-height:1.6}
.pf-arrow{position:absolute;right:-1px;top:50%;transform:translateY(-50%);width:2px;height:40px;background:var(--indigo);opacity:.3;z-index:1}

/* DEMO CALCULATOR */
.demo-wrap{background:var(--surface);border:.5px solid var(--border);border-radius:24px;padding:3rem;margin-top:3rem;position:relative;overflow:hidden}
.demo-wrap::after{content:'ॐ';position:absolute;font-family:'Cormorant Garamond',serif;font-size:18rem;color:var(--lav);opacity:.025;top:50%;right:-2rem;transform:translateY(-50%);pointer-events:none;line-height:1}
.demo-grid{display:grid;grid-template-columns:1fr 1fr 1fr 1fr;gap:.75rem;margin-bottom:1.25rem}
.demo-input{background:rgba(196,181,253,.06);border:.5px solid var(--border2);border-radius:10px;padding:.75rem 1rem;color:var(--text);font-size:.82rem;font-family:'DM Sans',sans-serif;outline:none;width:100%;transition:border .2s}
.demo-input:focus{border-color:rgba(196,181,253,.35)}
.demo-select{background:rgba(196,181,253,.06);border:.5px solid var(--border2);border-radius:10px;padding:.75rem 1rem;color:var(--text);font-size:.82rem;font-family:'DM Sans',sans-serif;outline:none;width:100%;cursor:pointer}
.demo-select option{background:#0d0920}
.demo-btn{width:100%;background:var(--indigo);color:white;border:none;border-radius:10px;padding:.78rem;font-family:'DM Sans',sans-serif;font-size:.85rem;cursor:pointer;transition:all .2s;margin-top:.25rem}
.demo-btn:hover{opacity:.85}
.demo-result{margin-top:2rem;display:none}
.demo-result.show{display:grid;grid-template-columns:1fr 1fr;gap:1.5rem}
.dr-main{background:rgba(83,74,183,.08);border:.5px solid rgba(83,74,183,.2);border-radius:16px;padding:1.75rem;text-align:center}
.dr-mantra{font-family:'Cormorant Garamond',serif;font-size:1.3rem;color:var(--lav);letter-spacing:.08em;margin-bottom:.4rem}
.dr-meaning{font-size:.72rem;color:var(--textd);font-style:italic;line-height:1.6;margin-bottom:1rem}
.dr-freq-main{font-family:'Cormorant Garamond',serif;font-size:3rem;color:var(--gold);font-weight:300;line-height:1}
.dr-freq-name{font-size:.72rem;color:var(--textd);margin-top:.2rem}
.dr-sequence{background:var(--surface);border:.5px solid var(--border);border-radius:16px;padding:1.5rem}
.dr-seq-title{font-size:.62rem;letter-spacing:.18em;text-transform:uppercase;color:var(--textg);margin-bottom:1rem}
.dr-seq-item{display:flex;align-items:center;gap:.85rem;padding:.65rem 0;border-bottom:.5px solid rgba(196,181,253,.05)}
.dr-seq-item:last-child{border-bottom:none}
.dr-seq-hz{font-family:'Cormorant Garamond',serif;font-size:1.1rem;color:var(--gold);opacity:.7;width:55px;flex-shrink:0}
.dr-seq-info{flex:1}
.dr-seq-name{font-size:.72rem;color:var(--lav);font-weight:400}
.dr-seq-time{font-size:.62rem;color:var(--textd)}
.dr-seq-now{font-size:.6rem;color:var(--green);margin-left:.5rem}
.dr-explain{margin-top:1.5rem;display:none}
.dr-explain.show{display:grid;grid-template-columns:1fr 1fr 1fr;gap:.75rem}
.dex{background:var(--iglow);border:.5px solid rgba(83,74,183,.15);border-radius:11px;padding:.9rem 1.1rem}
.dex-label{font-size:.58rem;letter-spacing:.15em;text-transform:uppercase;color:var(--textg);margin-bottom:.35rem}
.dex-val{font-size:.78rem;color:var(--lav);font-weight:400;margin-bottom:.18rem}
.dex-desc{font-size:.67rem;color:var(--textd);line-height:1.5}

/* TRADITIONS */
.trad-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.25rem;margin-top:3rem}
.trad-card{background:var(--surface);border:.5px solid var(--border);border-radius:20px;padding:2rem;transition:all .3s;position:relative;overflow:hidden}
.trad-card:hover{background:var(--surface2);border-color:var(--border2);transform:translateY(-3px)}
.trad-card::after{content:'';position:absolute;bottom:0;left:0;right:0;height:2px;opacity:0;transition:opacity .3s}
.trad-card:hover::after{opacity:1}
.trad-icon{font-size:1.75rem;margin-bottom:1rem;opacity:.55;display:block}
.trad-name{font-size:.78rem;font-weight:500;color:var(--lav);letter-spacing:.05em;margin-bottom:.25rem}
.trad-origin{font-size:.6rem;color:var(--goldd);letter-spacing:.12em;text-transform:uppercase;margin-bottom:.75rem}
.trad-desc{font-size:.78rem;color:var(--textd);line-height:1.75}
.trad-contrib{margin-top:.85rem;background:var(--iglow);border:.5px solid rgba(83,74,183,.15);border-radius:9px;padding:.6rem .85rem;font-size:.7rem;color:var(--lav);font-style:italic}

/* USE CASES — STREAMING */
.use-hero{background:linear-gradient(135deg,rgba(83,74,183,.08) 0%,rgba(232,197,71,.04) 100%);border:.5px solid rgba(83,74,183,.18);border-radius:28px;padding:4rem 3rem;margin-top:1rem;text-align:center;position:relative;overflow:hidden}
.use-hero::before{content:'';position:absolute;top:-50%;left:-50%;width:200%;height:200%;background:radial-gradient(ellipse 60% 40% at 50% 50%,rgba(83,74,183,.06) 0%,transparent 70%);pointer-events:none}
.use-title{font-family:'Cormorant Garamond',serif;font-size:clamp(1.6rem,3.5vw,2.5rem);font-weight:300;color:var(--lav);margin-bottom:1rem;position:relative;z-index:2}
.use-desc{font-size:.92rem;color:var(--textd);line-height:1.9;max-width:620px;margin:0 auto 2.5rem;position:relative;z-index:2}
.use-cases-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.25rem;margin-top:3rem}
.uc-card{background:var(--surface);border:.5px solid var(--border);border-radius:20px;padding:2rem 1.75rem;transition:all .3s;text-align:left}
.uc-card:hover{background:var(--surface2);border-color:var(--border2);transform:translateY(-3px)}
.uc-icon{font-size:1.5rem;margin-bottom:1rem;opacity:.6;display:block}
.uc-title{font-size:.82rem;font-weight:500;color:var(--lav);margin-bottom:.5rem}
.uc-desc{font-size:.78rem;color:var(--textd);line-height:1.75}
.uc-tag{display:inline-block;background:var(--golddim);border:.5px solid rgba(232,197,71,.2);border-radius:100px;font-size:.6rem;color:var(--goldd);padding:.2rem .65rem;margin-top:.75rem;letter-spacing:.06em;text-transform:uppercase}

/* HOW STREAM WORKS */
.stream-flow{display:grid;grid-template-columns:repeat(5,1fr);align-items:center;gap:0;margin-top:3rem}
.sf-step{text-align:center;padding:1.5rem 1rem;position:relative}
.sf-icon{width:52px;height:52px;border-radius:50%;background:var(--iglow);border:.5px solid rgba(83,74,183,.25);display:flex;align-items:center;justify-content:center;margin:0 auto .75rem;font-size:1.1rem}
.sf-title{font-size:.72rem;font-weight:500;color:var(--lav);margin-bottom:.3rem}
.sf-desc{font-size:.65rem;color:var(--textd);line-height:1.55}
.sf-arrow{display:flex;align-items:center;justify-content:center;color:var(--border2);font-size:1.2rem;padding-top:1.5rem}

/* TRANSPARENCY */
.transparency-block{background:rgba(83,74,183,.05);border:.5px solid rgba(83,74,183,.15);border-radius:24px;padding:3.5rem;margin-top:1rem}
.tb-title{font-family:'Cormorant Garamond',serif;font-size:1.5rem;font-weight:300;color:var(--lav);margin-bottom:1.25rem}
.tb-text{font-size:.88rem;color:var(--textd);line-height:1.95;max-width:680px}
.tb-items{display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-top:1.75rem}
.tb-item{display:flex;align-items:flex-start;gap:.75rem}
.tb-check{width:22px;height:22px;border-radius:50%;background:var(--iglow);border:.5px solid rgba(83,74,183,.3);display:flex;align-items:center;justify-content:center;font-size:.65rem;color:var(--indigo2);flex-shrink:0;margin-top:.1rem}
.tb-item-text{font-size:.78rem;color:var(--textd);line-height:1.6}
.tb-quote{font-family:'Cormorant Garamond',serif;font-size:1.1rem;font-style:italic;color:var(--lavd);border-left:2px solid var(--indigo);padding-left:1.5rem;margin-top:1.75rem;line-height:1.7}

/* PLANS */
.plans-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1rem;margin-top:3rem}
.pcard{background:var(--surface);border:.5px solid var(--border);border-radius:22px;padding:2.25rem 1.75rem;position:relative;transition:transform .3s}
.pcard:hover{transform:translateY(-4px)}
.pcard.hot{border-color:rgba(83,74,183,.4);background:rgba(83,74,183,.07)}
.pcard.premium{border-color:rgba(232,197,71,.3);background:rgba(232,197,71,.04)}
.p-badge{position:absolute;top:-1px;left:50%;transform:translateX(-50%);font-size:.58rem;letter-spacing:.12em;text-transform:uppercase;padding:.25rem 1.25rem;border-radius:0 0 10px 10px;white-space:nowrap}
.p-badge.purple{background:var(--indigo);color:rgba(255,255,255,.92)}
.p-badge.gold{background:var(--gold);color:#1a0f00;font-weight:500}
.p-name{font-size:.62rem;letter-spacing:.2em;text-transform:uppercase;color:var(--textg);margin-bottom:.9rem}
.p-price{font-family:'Cormorant Garamond',serif;font-size:2.8rem;font-weight:300;color:var(--lav);line-height:1}
.p-price-small{font-size:1.4rem}
.p-period{font-size:.7rem;color:var(--textd);margin-top:.2rem;margin-bottom:1.5rem}
.p-feats{list-style:none;display:flex;flex-direction:column;gap:.5rem;margin-bottom:1.75rem}
.p-feats li{font-size:.73rem;color:var(--textd);display:flex;align-items:flex-start;gap:.5rem;line-height:1.45}
.p-feats li::before{content:'—';color:var(--indigo2);flex-shrink:0;margin-top:.05rem}
.p-feats li.off{opacity:.22}
.p-feats li.off::before{content:'·'}
.p-feats li.gold-feat{color:rgba(232,197,71,.75)}
.p-feats li.gold-feat::before{content:'★';color:var(--gold);opacity:.7}
.pbtn{display:block;text-align:center;padding:.72rem;border-radius:10px;font-size:.76rem;text-decoration:none;transition:all .2s;font-family:'DM Sans',sans-serif;cursor:pointer;border:none}
.pbtn-solid{background:var(--indigo);color:white}
.pbtn-solid:hover{opacity:.85}
.pbtn-outline{border:.5px solid var(--border2);color:var(--lavd);background:transparent}
.pbtn-outline:hover{border-color:var(--lavd);color:var(--lav)}
.pbtn-gold{background:var(--gold);color:#1a0f00;font-weight:500}
.pbtn-gold:hover{opacity:.88}

/* 30 DAY SPECIAL */
.thirty-day{background:linear-gradient(135deg,rgba(232,197,71,.08) 0%,rgba(83,74,183,.06) 100%);border:.5px solid rgba(232,197,71,.2);border-radius:28px;padding:4rem 3rem;margin-top:2rem;display:grid;grid-template-columns:1fr 1fr;gap:3rem;align-items:center}
.td-left h3{font-family:'Cormorant Garamond',serif;font-size:clamp(1.5rem,3vw,2.2rem);font-weight:300;color:var(--gold);margin-bottom:1rem;line-height:1.2}
.td-left p{font-size:.88rem;color:var(--textd);line-height:1.9;margin-bottom:1.5rem}
.td-scenarios{display:flex;flex-direction:column;gap:.65rem}
.td-scenario{display:flex;align-items:center;gap:.75rem;font-size:.78rem;color:var(--textd)}
.td-scenario-icon{width:30px;height:30px;border-radius:8px;background:var(--golddim);border:.5px solid rgba(232,197,71,.18);display:flex;align-items:center;justify-content:center;font-size:.8rem;flex-shrink:0}
.td-right{background:var(--surface);border:.5px solid rgba(232,197,71,.15);border-radius:20px;padding:2rem}
.td-price-block{text-align:center;margin-bottom:1.75rem}
.td-price{font-family:'Cormorant Garamond',serif;font-size:3rem;font-weight:300;color:var(--gold);line-height:1}
.td-period{font-size:.72rem;color:var(--textd);margin-top:.2rem}
.td-features{list-style:none;display:flex;flex-direction:column;gap:.55rem;margin-bottom:1.5rem}
.td-features li{font-size:.75rem;color:var(--textd);display:flex;align-items:flex-start;gap:.5rem;line-height:1.45}
.td-features li::before{content:'★';color:var(--gold);opacity:.6;flex-shrink:0;font-size:.6rem;margin-top:.15rem}

/* TESTIMONIALS */
.testi-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.25rem;margin-top:2.5rem}
.tcard{background:var(--surface);border:.5px solid var(--border);border-radius:20px;padding:1.75rem;transition:all .3s}
.tcard:hover{background:var(--surface2)}
.tcard-stars{display:flex;gap:.2rem;margin-bottom:1rem}
.tcard-star{color:var(--gold);opacity:.7;font-size:.75rem}
.tcard-text{font-family:'Cormorant Garamond',serif;font-size:1rem;font-style:italic;color:var(--textd);line-height:1.75;margin-bottom:1.25rem}
.tcard-author{display:flex;align-items:center;gap:.65rem}
.tcard-av{width:34px;height:34px;border-radius:50%;background:var(--iglow);border:.5px solid rgba(83,74,183,.2);display:flex;align-items:center;justify-content:center;font-size:.65rem;color:var(--lavd);font-weight:500;flex-shrink:0}
.tcard-name{font-size:.78rem;font-weight:500;color:var(--lav)}
.tcard-role{font-size:.65rem;color:var(--textg)}

/* FAQ */
.faq-list{display:flex;flex-direction:column;gap:.75rem;margin-top:2.5rem;max-width:720px}
.faq-item{background:var(--surface);border:.5px solid var(--border);border-radius:14px;overflow:hidden;transition:border .2s}
.faq-item.open{border-color:rgba(83,74,183,.25)}
.faq-q{padding:1.1rem 1.5rem;display:flex;align-items:center;justify-content:space-between;cursor:pointer;font-size:.82rem;color:var(--text);font-weight:400;transition:color .2s}
.faq-q:hover{color:var(--lav)}
.faq-arrow{font-size:.7rem;color:var(--textg);transition:transform .3s;flex-shrink:0}
.faq-item.open .faq-arrow{transform:rotate(180deg)}
.faq-a{max-height:0;overflow:hidden;transition:max-height .4s ease,padding .3s}
.faq-item.open .faq-a{max-height:200px;padding:0 1.5rem 1.1rem}
.faq-a-text{font-size:.78rem;color:var(--textd);line-height:1.8}

/* CTA FINAL */
.cta-final{text-align:center;padding:6rem 2rem;position:relative;overflow:hidden}
.cta-final-glow{position:absolute;width:600px;height:400px;border-radius:50%;background:radial-gradient(ellipse,rgba(83,74,183,.1) 0%,transparent 70%);top:50%;left:50%;transform:translate(-50%,-50%);pointer-events:none}

/* FOOTER */
footer{border-top:.5px solid var(--border);padding:3rem 4rem;display:grid;grid-template-columns:1fr 2fr 1fr;align-items:center;gap:2rem}
.f-logo{font-family:'Cormorant Garamond',serif;font-size:1.4rem;font-weight:300;letter-spacing:.2em;color:var(--lav);opacity:.3}
.f-text{font-size:.68rem;color:var(--textg);line-height:1.8;text-align:center}
.f-links{display:flex;gap:1.5rem;justify-content:flex-end}
.f-links a{font-size:.68rem;color:var(--textg);text-decoration:none;transition:color .2s}
.f-links a:hover{color:var(--lavd)}

/* REVEAL */
.rv{opacity:0;transform:translateY(24px);transition:opacity .85s ease,transform .85s ease}
.rv.vis{opacity:1;transform:translateY(0)}
.rv2{opacity:0;transform:translateY(16px);transition:opacity .7s ease,transform .7s ease}
.rv2.vis{opacity:1;transform:translateY(0)}

/* RESPONSIVE */
@media(max-width:1024px){
  .freq7-grid{grid-template-columns:repeat(4,1fr)}
  .plans-grid{grid-template-columns:repeat(2,1fr)}
  .thirty-day{grid-template-columns:1fr}
  .stream-flow{grid-template-columns:1fr}
  .sf-arrow{display:none}
  footer{grid-template-columns:1fr;text-align:center}
  .f-links{justify-content:center}
  nav{padding:1rem 1.5rem}
  .trust{padding:1rem 1.5rem;gap:1.25rem}
}
@media(max-width:768px){
  .freq7-grid{grid-template-columns:repeat(2,1fr)}
  .persona-flow{grid-template-columns:1fr}
  .trad-grid,.use-cases-grid,.testi-grid{grid-template-columns:1fr}
  .demo-grid{grid-template-columns:1fr 1fr}
  .demo-result.show{grid-template-columns:1fr}
  .dr-explain.show{grid-template-columns:1fr}
  .tb-items{grid-template-columns:1fr}
  .nlinks{display:none}
  .sec,.sec-sm{padding:4rem 1.25rem}
}
</style>
</head>
<body>

<nav>
  <div class="nlogo">ŌHM</div>
  <ul class="nlinks">
